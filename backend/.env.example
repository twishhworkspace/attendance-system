# Database connection string
DATABASE_URL="postgresql://user:password@localhost:5432/attendance_db?schema=public"

# Secret key for JWT signing
JWT_SECRET="generate_a_long_random_string_here"

# Server Configuration
PORT=5000
NODE_ENV=production
SECURITY_DISABLED=false

# Deployment & CORS
FRONTEND_URL="https://attendance-system-gamma-ecru.vercel.app"

# Passkey (Biometric) Configuration
RP_ID="attendance-system-gamma-ecru.vercel.app"
ORIGIN="https://attendance-system-gamma-ecru.vercel.app"

# Geofencing & Verification
GEOFENCE_STRICT_MODE=false
MAX_GPS_ACCURACY=100

# Email Service (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
