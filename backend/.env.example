# Database connection string
DATABASE_URL="postgresql://user:password@localhost:5432/attendance_db?schema=public"

# Secret key for JWT signing
JWT_SECRET="generate_a_long_random_string_here"

# Server Configuration
PORT=5000
NODE_ENV=development # change to 'production' on Render
SECURITY_DISABLED=false

# Deployment & CORS
FRONTEND_URL="http://localhost:5173"

# Passkey (Biometric) Configuration
RP_ID="localhost" # change to your domain on Render (e.g., 'your-app.onrender.com')
ORIGIN="http://localhost:5173" # change to your frontend URL on Vercel

# Geofencing & Verification
GEOFENCE_STRICT_MODE=false
MAX_GPS_ACCURACY=100
